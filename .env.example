# =====================================================
# Configuración de entorno
# Copiar este archivo como .env y completar los valores.
# =====================================================

# --- Django ---
SECRET_KEY="django-insecure-dev-secret-key-change-in-production"
DEBUG=True
ALLOWED_HOSTS="localhost,127.0.0.1"

# --- Base de datos (PostgreSQL 14+; driver psycopg v3) ---
# Opción 1 (recomendada): URL completa
# DATABASE_URL="postgresql://usuario:password@localhost:5432/erp_db"

# Opción 2: variables individuales
DB_NAME="erp_db"
DB_USER="postgres"
DB_PASSWORD="cambiar_password"
DB_HOST="localhost"
DB_PORT="5432"

# --- Integraciones (opcionales) ---
# MercadoLibre
ML_CLIENT_ID=""
ML_CLIENT_SECRET=""
ML_REDIRECT_URI="http://localhost:3000/integrations/mercadolibre/callback"

# Zoho ZeptoMail (sólo producción)
ZOHO_ZEPTOMAIL_API_KEY_TOKEN=""
ZOHO_ZEPTOMAIL_HOSTED_REGION="zeptomail.zoho.com"
DEFAULT_FROM_EMAIL="noreply@tudominio.com"
SERVER_EMAIL="noreply@tudominio.com"
