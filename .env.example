# Django Settings
SECRET_KEY="django-insecure-dev-secret-key-change-in-production"
DEBUG=True

# Database Configuration (PostgreSQL 18+ obligatorio, driver psycopg v3)
# Opción 1 (recomendada): URL completa
# DATABASE_URL="postgresql://usuario:password@localhost:5432/apice_crm"

# Opción 2: variables individuales
DB_NAME="apice_crm"
DB_USER="postgres"
DB_PASSWORD="tu_password_seguro"
DB_HOST="localhost"
DB_PORT="5432"

# MercadoLibre Integration
ML_CLIENT_ID=""
ML_CLIENT_SECRET=""
